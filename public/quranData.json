{
  "ayahs": [
    {
      "id": 1,
      "surah": "Al-Fatiha",
      "ayah": 1,
      "text": "In the name of Allah, the Most Gracious, the Most Merciful.",
      "translation": "Bismillahir Rahmanir Rahim",
      "audio": "/audio/fatiha1.mp3"
    },
    {
      "id": 2,
      "surah": "Al-Fatiha",
      "ayah": 2,
      "text": "All praise is due to Allah, Lord of the worlds.",
      "translation": "Alhamdu lillahi rabbil 'alamin",
      "audio": "/audio/fatiha2.mp3"
    },
    {
      "id": 3,
      "surah": "Al-Baqarah",
      "ayah": 255,
      "text": "Allah! There is no deity except Him, the Ever-Living, the Sustainer of existence.",
      "translation": "Ayatul Kursi",
      "audio": "/audio/baqarah255.mp3"
    },
    {
      "id": 4,
      "surah": "Al-Ikhlas",
      "ayah": 1,
      "text": "Say, He is Allah, One.",
      "translation": "Qul huwa Allahu ahad",
      "audio": "/audio/ikhlas1.mp3"
    },
    {
      "id": 5,
      "surah": "Al-Falaq",
      "ayah": 1,
      "text": "Say, I seek refuge in the Lord of daybreak.",
      "translation": "Qul a'udhu bi rabbil falaq",
      "audio": "/audio/falaq1.mp3"
    },
    {
      "id": 6,
      "surah": "An-Nas",
      "ayah": 1,
      "text": "Say, I seek refuge in the Lord of mankind.",
      "translation": "Qul a'udhu bi rabbin nas",
      "audio": "/audio/nas1.mp3"
    }
  ],

  "hadiths": [
    {
      "id": 1,
      "text": "Actions are judged by intentions.",
      "source": "Sahih Bukhari"
    },
    {
      "id": 2,
      "text": "The best among you are those who have the best manners.",
      "source": "Sahih Bukhari"
    },
    {
      "id": 3,
      "text": "Allah does not look at your appearance, but at your hearts.",
      "source": "Sahih Muslim"
    }
  ],

